#compdef iftop

local arguments

arguments=(
  '-h[display help message]'
  '-n[dont do hostname lookups]'
  '-N[dont convert port numbers to services]'
  '-p[run in promiscuous mode (sniff all traffic on the local net segment)]'
  '-b[dont display a bar graph of traffic]'
  '-B[display bandwidth in bytes]'
  '-i[listen on named interface]:interface:_net_interfaces'
  '-f[use BPF filter code to select packets to count]:filter code:'
  '-F[show traffic flows in/out of IPv4 network]:net/mask:'
  '-G[show traffic flows in/out of IPv6 network]:net6/mask6:'
  '-l[display and count link-local IPv6 traffic]'
  '-P[show ports as well as hosts]'
  '-m[set upper limit for the bandwidth scale]:limit:'
  '-c[load alternate configuration file]:config file:_files'
  '-o[output in JSON or CSV format (non-interactive)]:format:(json csv)'
  '-t[capture duration in seconds for export mode]:seconds:'
  '-Z[show owning process per flow]'
  '*:filename:_files'
)

_arguments -s $arguments
